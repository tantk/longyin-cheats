  MT.ui.makeInput(tabGeneral, COL2_X, y2, BTN_W, BTN_H, "武学上限 SkillLimit", 80, "99", MT.cheats.stats.setSkillLimit, false)
  y2 = y2 + ROW_H

  MT.ui.makeToggleInput(tabGeneral, COL2_X, y2, BTN_W, BTN_H, "武学天才 CombatEXP %", 80, "300",
    MT.cheats.stats.combatExpEnable, MT.cheats.stats.combatExpDisable, false)
  y2 = y2 + ROW_H

  MT.ui.makeToggleInput(tabGeneral, COL2_X, y2, BTN_W, BTN_H, "博学多才 LivingEXP %", 80, "300",
    MT.cheats.stats.livingExpEnable, MT.cheats.stats.livingExpDisable, false)
