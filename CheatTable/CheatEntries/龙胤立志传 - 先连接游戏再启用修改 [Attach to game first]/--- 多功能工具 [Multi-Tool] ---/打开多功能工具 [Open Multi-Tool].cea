  sectionLabel(tabGeneral, COL2_X, y2, "战斗 Battle")
  y2 = y2 + 24

  MT.ui.makeOneOff(tabGeneral, COL2_X, y2, BTN_W, BTN_H, "恢复生命 RestoreHP", MT.cheats.stats.restoreHP, false)
  y2 = y2 + ROW_H

  MT.ui.makeOneOff(tabGeneral, COL2_X, y2, BTN_W, BTN_H, "清除伤势 ClearInjury", MT.cheats.stats.clearInjury, false)
