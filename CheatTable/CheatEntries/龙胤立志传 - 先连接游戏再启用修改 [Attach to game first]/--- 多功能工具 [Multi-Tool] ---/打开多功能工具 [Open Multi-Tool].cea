  MT.ui.makeOneOff(tabGeneral, COL2_X, y2, BTN_W, BTN_H, "清除伤势 ClearInjury", MT.cheats.stats.clearInjury, false)
  y2 = y2 + ROW_H

  MT.ui.makeToggleInput(tabGeneral, COL2_X, y2, BTN_W, BTN_H, "战斗加速 BattleSpd (1-999)", 80, "50",
    MT.cheats.battle.battleSpeedEnable, MT.cheats.battle.battleSpeedDisable, false)
  y2 = y2 + ROW_H

  MT.ui.makeOneOff(tabGeneral, COL2_X, y2, BTN_W, BTN_H, "敌人1血 Enemy1HP", MT.cheats.battle.enemyOneHP, false)
  y2 = y2 + ROW_H + SECTION_GAP

  sectionLabel(tabGeneral, COL2_X, y2, "武学 Skills")
  y2 = y2 + HH

  MT.ui.makeInput(tabGeneral, COL2_X, y2, BTN_W, BTN_H, "武学上限 SkillLimit", 80, "99", MT.cheats.stats.setSkillLimit, false)
  y2 = y2 + ROW_H

  MT.ui.makeToggleInput(tabGeneral, COL2_X, y2, BTN_W, BTN_H, "武学天才 CombatEXP %", 80, "300",
    MT.cheats.stats.combatExpEnable, MT.cheats.stats.combatExpDisable, false)
  y2 = y2 + ROW_H

  MT.ui.makeToggleInput(tabGeneral, COL2_X, y2, BTN_W, BTN_H, "博学多才 LivingEXP %", 80, "300",
    MT.cheats.stats.livingExpEnable, MT.cheats.stats.livingExpDisable, false)
  y2 = y2 + ROW_H + SECTION_GAP

  sectionLabel(tabGeneral, COL2_X, y2, "探索 Exploration")
  y2 = y2 + HH

  MT.ui.makeToggleInput(tabGeneral, COL2_X, y2, BTN_W, BTN_H, "坐骑加速 HorseSpd (1-500)", 80, "100",
    MT.cheats.explore.horseSpeedEnable, MT.cheats.explore.horseSpeedDisable, false)
  y2 = y2 + ROW_H

  MT.ui.makeOneOff(tabGeneral, COL2_X, y2, BTN_W, BTN_H, "迷宫全开 DungeonReveal", MT.cheats.explore.dungeonReveal, true)
  y2 = y2 + ROW_H

  MT.ui.makeOneOff(tabGeneral, COL2_X, y2, BTN_W, BTN_H, "无限耐力 InfiniteStamina", MT.cheats.explore.infiniteStamina, true)
  y2 = y2 + ROW_H

  -- ======== COLUMN 3: Character Creation ========
  local y3 = 8
  sectionLabel(tabGeneral, COL3_X, y3, "角色创建 CharCreate")
  y3 = y3 + HH

  MT.ui.makeInput(tabGeneral, COL3_X, y3, BTN_W, BTN_H, "属性点 AttrPts", 80, "999", MT.cheats.stats.setAttrPoints, false)
  y3 = y3 + ROW_H

  MT.ui.makeInput(tabGeneral, COL3_X, y3, BTN_W, BTN_H, "武学点 FightPts", 80, "999", MT.cheats.stats.setFightPoints, false)
  y3 = y3 + ROW_H

  MT.ui.makeInput(tabGeneral, COL3_X, y3, BTN_W, BTN_H, "生活点 LivingPts", 80, "999", MT.cheats.stats.setLivingPoints, false)
  y3 = y3 + ROW_H

  MT.ui.makeInput(tabGeneral, COL3_X, y3, BTN_W, BTN_H, "天赋点 TalentPts", 80, "999", MT.cheats.stats.setCreationTalentPoints, false)
  y3 = y3 + ROW_H

  MT.ui.makeToggleInput(tabGeneral, COL3_X, y3, BTN_W, BTN_H, "天赋槽 TalentSlots", 80, "50",
