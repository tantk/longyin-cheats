[ENABLE]
{$lua}
if syntaxcheck then return end
if type(MT) ~= "table" or not MT.ui then
  local err = (type(MT) == "table" and MT._loadError) or "MT not defined"
  showMessage("修改器加载失败 / Multi-Tool failed to load:\n\n" .. tostring(err) .. "\n\n请关闭CE后重新打开再加载CT\nPlease close CE completely, reopen, then load CT.")
  return
end
if _itemAdderForm then _itemAdderForm.destroy(); _itemAdderForm = nil end

local _formOk, _formErr = pcall(function()
-- ============================================================
-- Multi-Tool v8 Form
-- All logic, helpers, databases, hooks, and item/hero/event
-- functions are in LuaScript.lua under the MT.* namespace.
-- This file only creates the GUI and wires callbacks.
-- ============================================================

-- ============================================================
-- DESIGN SYSTEM — change F to scale entire form
-- Derived from analysis/desktop_ui_design_guide.md
-- ============================================================
local F   = 13            -- body font size (all controls inherit)
local FH  = F + 1         -- 14, section headers
local FN  = F - 3         -- 10, hints/status bar
local BH  = 36            -- button height (F*2.5 → 4px grid)
local RH  = 44            -- row height (BH + 8)
local EH  = 32            -- edit height (F*2 + 6)
local SG  = 16            -- section gap
local HH  = 28            -- section header line height
local MG  = 12            -- margin
local CG  = 20            -- column gap
local TH  = 48            -- top bar height
local CW  = 400           -- column width
local FW  = MG + CW + CG + CW + CG + CW + MG  -- 1264
local FMHH = 820          -- form height

local frm = createForm(false)
frm.Caption = "龙吟利志传 Multi-Tool v8"
frm.Font.Name = "Microsoft YaHei"
frm.Font.Size = F
frm.Width = FW
frm.Height = FMHH
frm.BorderStyle = bsSizeable
frm.Position = poScreenCenter
frm.FormStyle = fsStayOnTop

-- ============================================================
-- TOP BAR
-- ============================================================

local pnlTop = createPanel(frm)
pnlTop.Left = 0; pnlTop.Top = 0; pnlTop.Width = FW; pnlTop.Height = TH
pnlTop.BevelOuter = 0
pnlTop.Color = 0xF0F0F0
pnlTop.Caption = ""

local btnConnect = createButton(pnlTop)
btnConnect.Left = MG; btnConnect.Top = 6; btnConnect.Width = 200; btnConnect.Height = BH
btnConnect.Caption = "连接游戏 [Connect]"
btnConnect.Font.Size = FH
btnConnect.Font.Style = fsBold

local lblConnStatus = createLabel(pnlTop)
lblConnStatus.Left = 220; lblConnStatus.Top = 14
lblConnStatus.Caption = "未连接 [Not connected]"
lblConnStatus.Font.Color = 0x0000FF  -- red BGR

local function readDiagTail(path, maxLines, maxChars)
  local f = path and io.open(path, "r") or nil
  local lines = {}
  maxLines = maxLines or 200
  if f then
    for line in f:lines() do
      lines[#lines + 1] = line
      if #lines > maxLines then table.remove(lines, 1) end
    end
    f:close()
  elseif type(_mtDiagMem) == "table" and #_mtDiagMem > 0 then
    local start = math.max(1, #_mtDiagMem - maxLines + 1)
    for i = start, #_mtDiagMem do
      lines[#lines + 1] = _mtDiagMem[i]
    end
  else
    return nil, "diag unavailable: no readable file and no memory buffer"
  end
  local txt = table.concat(lines, "\n")
  if maxChars and #txt > maxChars then
    txt = txt:sub(#txt - maxChars + 1)
  end
  return txt
end

local btnCopyDiag = createButton(pnlTop)
btnCopyDiag.Left = FW - 220; btnCopyDiag.Top = 6; btnCopyDiag.Width = 200; btnCopyDiag.Height = BH
btnCopyDiag.Caption = "复制诊断 [Copy Diag]"
btnCopyDiag.Font.Size = 13

btnCopyDiag.OnClick = function(sender)
  local ok, err = pcall(function()
    local pid = getOpenedProcessID() or 0
    local diagPath = nil
    if type(MT) == "table" then
      if type(MT.getDiagPath) == "function" then
        local okPath, p = pcall(MT.getDiagPath)
        if okPath then diagPath = p end
      end
      if (not diagPath or diagPath == "") and type(MT.diagPath) == "string" then
        diagPath = MT.diagPath
      end
    end
    if not diagPath or diagPath == "" then
      diagPath = (os.getenv("TEMP") or ".") .. "\\ce_mt_load_diag.log"
    end
    -- Keep under 1000 chars (Bilibili comment limit)
    local tail, tailErr = readDiagTail(diagPath, 40, 600)
    local lines = {
      "=== LongYin Diag ===",
      os.date("%Y-%m-%d %H:%M:%S") .. " PID:" .. tostring(pid),
    }
    if type(MT) == "table" and MT._loadError then
      lines[#lines + 1] = "ERR:" .. tostring(MT._loadError)
    end
    lines[#lines + 1] = tail or ("(no log) " .. tostring(tailErr))
    local payload = table.concat(lines, "\n")

    if type(writeToClipboard) == "function" then
      writeToClipboard(payload)
    elseif type(copyToClipboard) == "function" then
      copyToClipboard(payload)
    else
      error("Clipboard API unavailable")
    end

    if type(MT) == "table" and type(MT.diag) == "function" then
      pcall(MT.diag, "[ui] diagnostics copied from top bar button")
    end
    lblConnStatus.Caption = "诊断已复制 [Diag copied]"
    lblConnStatus.Font.Color = 0x008000
    if type(MT) == "table" and MT.ui and MT.ui.setStatus then
      MT.ui.setStatus("Diagnostics copied to clipboard", 0x008000)
    end
  end)
  if not ok then
    lblConnStatus.Caption = "复制失败 [Copy failed]"
    lblConnStatus.Font.Color = 0x0000FF
    if type(MT) == "table" and MT.ui and MT.ui.setStatus then
      MT.ui.setStatus("ERR: " .. tostring(err), 0x0000FF)
    end
    showMessage("复制诊断失败 / Copy diagnostics failed:\n\n" .. tostring(err))
  end
end

btnConnect.OnClick = function(sender)
  local ok, err = pcall(function()
    local pid = getOpenedProcessID()
    if not pid or pid == 0 then error("请先用CE连接游戏 [Attach CE to game first]") end
    -- Force refresh symbols in case process changed
    _il2cppCache = nil
    reinitializeSymbolhandler()
    local ga = getAddress("GameAssembly.dll")
    if not ga or ga == 0 then
      error("找不到GameAssembly.dll [GameAssembly.dll not found — reattach CE]")
    end
    lblConnStatus.Caption = "连接中... [Connecting...]"
    lblConnStatus.Font.Color = 0x008080
    MT.ui.setStatus("连接中... [Connecting...]", 0x008080)
    local discoverOk, discoverMsg = MT.hook.discover(false)  -- full mode: resolve all RVAs for items/heroes
    if not discoverOk then error(tostring(discoverMsg)) end
    MT.hook.hookInstalled = true
    MT.ui.enableThreadControls()
    lblConnStatus.Caption = "已连接 [Connected]"
    lblConnStatus.Font.Color = 0x008000
    MT.ui.setStatus(discoverMsg or "Connected! Hook active.", 0x008000)
  end)
  if not ok then
    lblConnStatus.Caption = "连接失败 [Connection failed]"
    lblConnStatus.Font.Color = 0x0000FF
    MT.ui.setStatus("ERR: " .. tostring(err), 0x0000FF)
  end
end

-- ============================================================
-- TAB CONTROL (PageControl + 4 tabs)
-- ============================================================

local pc = createPageControl(frm)
pc.Left = 4; pc.Top = TH + 2; pc.Width = FW - 8; pc.Height = FMHH - TH - 50
pc.Font.Size = 14

local tabGeneral  = pc.addTab()  -- index 0
