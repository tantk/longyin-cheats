  MT.ui.makeOneOff(tabGeneral, COL1_X, y1, BTN_W, BTN_H, "门派好感 Affinity", MT.cheats.stats.maxFactionAffinity, false)
  y1 = y1 + ROW_H

  -- ======== COLUMN 2: Battle + Skills + Exploration ========
  local y2 = 8
