  MT.ui.makeInput(tabGeneral, COL1_X, y1, BTN_W, BTN_H, "门派贡献 SectCurrency", 80, "9999", MT.cheats.resources.setSectCurrency, false)
  y1 = y1 + ROW_H

  MT.ui.makeInput(tabGeneral, COL1_X, y1, BTN_W, BTN_H, "外门贡献 FactionContrib", 80, "999", MT.cheats.resources.setFactionContrib, false)
