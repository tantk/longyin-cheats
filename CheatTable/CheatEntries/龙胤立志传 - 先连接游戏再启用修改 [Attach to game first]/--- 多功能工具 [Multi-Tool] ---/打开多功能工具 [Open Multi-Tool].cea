end

-- ============================================================
-- SECT TAB -- single-column layout, sect-wide cheats + hero gen
-- ============================================================

do
  local SECT_X = MG
  local SECT_COL2 = MG + CW + CG  -- right column for hero gen
  local SECT_BTN_W = CW - MG
  local SECT_BTN_H = BH
  local SECT_ROW_H = RH
  local sectY = MG

  -- 1. Member Limit 门派人数上限 (toggle -- hooks GetMaxHeroNum + PopulationNotFull)
  MT.ui.makeToggleInput(tabSect, SECT_X, sectY, SECT_BTN_W, SECT_BTN_H, "人数上限 MemberLimit", 80, "300",
    MT.cheats.sect.memberLimitEnable, MT.cheats.sect.memberLimitDisable, true)
  sectY = sectY + SECT_ROW_H

  -- 2a. Sect Talent Points 全派天赋点
  MT.ui.makeInput(tabSect, SECT_X, sectY, SECT_BTN_W, SECT_BTN_H, "全派天赋点 SectTalentPts", 80, "99", MT.cheats.sect.setSectTalentPoints, false)
  sectY = sectY + SECT_ROW_H

  -- 2b. Sect Talent Slots 全派天赋槽
  MT.ui.makeInput(tabSect, SECT_X, sectY, SECT_BTN_W, SECT_BTN_H, "全派天赋槽 SectTalentSlots", 80, "99", MT.cheats.sect.setSectTalentSlots, false)
  sectY = sectY + SECT_ROW_H

  -- 3. Sect-Wide Prodigy 全门派武学天才+博学多才 (needs thread -- runtime_invoke via cmd=8)
  MT.ui.makeOneOff(tabSect, SECT_X, sectY, SECT_BTN_W, SECT_BTN_H, "全派天才+博学 SectProdigy", MT.cheats.sect.sectProdigy, true)
  sectY = sectY + SECT_ROW_H

  -- 4. Max Loyalty 全门派忠诚满
  MT.ui.makeOneOff(tabSect, SECT_X, sectY, SECT_BTN_W, SECT_BTN_H, "全派忠诚满 MaxLoyalty", MT.cheats.sect.maxLoyalty, false)
  sectY = sectY + SECT_ROW_H

  -- 5. Max Skill Slots 全门派武学槽位满
  MT.ui.makeOneOff(tabSect, SECT_X, sectY, SECT_BTN_W, SECT_BTN_H, "全派武学槽满 MaxSkillSlots", MT.cheats.sect.maxSkillSlots, false)
  sectY = sectY + SECT_ROW_H

  -- 6. Max Resources 门派资源填满
  MT.ui.makeOneOff(tabSect, SECT_X, sectY, SECT_BTN_W, SECT_BTN_H, "资源填满 MaxResources", MT.cheats.sect.maxResources, false)
  sectY = sectY + SECT_ROW_H

  -- 7. No Resource Cost 门派资源无消耗 (toggle -- AOB patch CostResource methods)
  MT.ui.makeToggle(tabSect, SECT_X, sectY, SECT_BTN_W, SECT_BTN_H, "资源无消耗 NoCost",
    MT.cheats.sect.noCostEnable, MT.cheats.sect.noCostDisable, false)
  sectY = sectY + SECT_ROW_H

  -- 8. Research -> 100% 研究进度100%
  MT.ui.makeOneOff(tabSect, SECT_X, sectY, SECT_BTN_W, SECT_BTN_H, "研究100% Research", MT.cheats.sect.research100, true)
  sectY = sectY + SECT_ROW_H

  -- 9. Build Time -> 1 Day 建筑剩余1天
  MT.ui.makeOneOff(tabSect, SECT_X, sectY, SECT_BTN_W, SECT_BTN_H, "建筑1天 Build1Day", MT.cheats.sect.build1Day, true)
  sectY = sectY + SECT_ROW_H

  -- 10. Generate Hero 生成角色 — right column
  local heroY = MG
  local lblHeroGen = createLabel(tabSect)
  lblHeroGen.Left = SECT_COL2; lblHeroGen.Top = heroY
  lblHeroGen.Caption = "生成角色 Generate Hero"
  lblHeroGen.Font.Size = FH; lblHeroGen.Font.Style = "[fsBold]"
  heroY = heroY + HH
  do
    local GH_ROW = RH - 6
    local GH_H = GH_ROW * 4 + 6
    local HERO_W = FW - SECT_COL2 - MG * 2
    local pnl = createPanel(tabSect)
    pnl.Left = SECT_COL2; pnl.Top = heroY; pnl.Width = HERO_W; pnl.Height = GH_H
    pnl.BevelOuter = 1
    pnl.Color = 0xC0C0C0
    pnl.Caption = ""

    -- Column positions for vertical alignment (longest label: "属性加成 Stats:" ~120px)
    local C1 = 0     -- labels column 1
    local C2 = 135   -- edits column 1 (fits "属性加成 Stats:")
    local C3 = 210   -- labels column 2
    local C4 = 325   -- edits column 2

    -- Row 1: Level + Sex
    local r1 = MT.ui.lay(pnl, {x=6, y=4, rowH=GH_ROW, btnH=GH_ROW-4}):inlineRow()
    r1:col(C1); r1:label("等级 Level:")
    r1:col(C2); local edtLv = r1:edit("0", 60)
    edtLv.Enabled = false
    r1:col(C3); r1:label("性别 Sex:")
    r1:col(C4); local cmbSex = r1:combo({"随机 Random","男 Male","女 Female"}, 160)
    cmbSex.Enabled = false

    -- Row 2: Age + Loyalty
    local r2 = MT.ui.lay(pnl, {x=6, y=4+GH_ROW, rowH=GH_ROW, btnH=GH_ROW-4}):inlineRow()
    r2:col(C1); r2:label("年龄 Age:")
    r2:col(C2); local edtAge = r2:edit("16", 60)
    edtAge.Enabled = false
    r2:col(C3); r2:label("忠诚 Loyalty:")
    r2:col(C4); local edtLoy = r2:edit("100", 70)
    edtLoy.Enabled = false

    -- Row 3: Stats
    local r3 = MT.ui.lay(pnl, {x=6, y=4+GH_ROW*2, rowH=GH_ROW, btnH=GH_ROW-4}):inlineRow()
    r3:col(C1); r3:label("属性加成 Stats:")
    r3:col(C2); local edtBoost = r3:edit("0", 60)
    edtBoost.Enabled = false
    r3:hintLabel("(0=默认 default)")

    -- Row 4: Recruit button
    local btnGen = createButton(pnl)
    btnGen.Left = 6; btnGen.Top = GH_ROW * 3 + 2; btnGen.Width = 150; btnGen.Height = GH_ROW - 4
    btnGen.Caption = "招募入派 Recruit"
    btnGen.Font.Size = 13
    btnGen.Enabled = false

    btnGen.Width = HERO_W - 12  -- full width of hero panel

    -- Register for thread gating
    table.insert(_threadGatedControls, {panel = pnl, btn = btnGen, edit = edtLv})
    table.insert(_threadGatedControls, {btn = cmbSex, edit = edtAge})
    table.insert(_threadGatedControls, {edit = edtLoy})
    table.insert(_threadGatedControls, {edit = edtBoost})

    -- Helper: boost stat lists to 50+boost
    local function boostList(heroPtr, baseOff, maxOff, boost)
      local baseList = readQword(heroPtr + baseOff)
      local maxList = readQword(heroPtr + maxOff)
      if not baseList or baseList == 0 then return end
      if not maxList or maxList == 0 then return end
      local items = readQword(baseList + 0x10)
      local size = readInteger(baseList + 0x18)
      for i = 0, (size or 0) - 1 do
        writeFloat(items + 0x20 + i * 4, 50 + boost)
      end
      items = readQword(maxList + 0x10)
      size = readInteger(maxList + 0x18)
      for i = 0, (size or 0) - 1 do
        local cur = readFloat(items + 0x20 + i * 4) or 0
        if cur < 50 + boost then writeFloat(items + 0x20 + i * 4, 50 + boost) end
      end
    end

    -- Helper: apply age, loyalty, stats boost to a newly generated hero
    local function applyHeroExtras(heroPtr)
      if not heroPtr or heroPtr == 0 then return end
      local age = tonumber(edtAge.Text) or 16
      local loyalty = tonumber(edtLoy.Text) or 100
      local boost = tonumber(edtBoost.Text) or 0
      writeInteger(heroPtr + 0xBC, age)
      writeFloat(heroPtr + 0x1CC, loyalty * 1.0)
      if boost > 0 then
        boostList(heroPtr, 0x128, 0x130, boost)  -- attri base+max
        boostList(heroPtr, 0x140, 0x148, boost)  -- fight base+max
        boostList(heroPtr, 0x158, 0x160, boost)  -- living base+max
      end
    end

    btnGen.OnClick = function(sender)
      local cap = "招募入派 Recruit"
      local ok, msg = pcall(function()
        MT.game.checkAlive()
        local lv = tonumber(edtLv.Text) or 20
        local sexIdx = cmbSex.ItemIndex  -- 0=random, 1=male, 2=female
        local hero = MT.game.getHero()
        if not hero then error("角色未找到 Hero not found") end
        local forceID = readInteger(hero + 0x84)
        local success, heroPtr = MT.heroes.generate(forceID, lv, sexIdx, 5000)
        if not success then error(heroPtr) end
        applyHeroExtras(heroPtr)
        return "招募成功 Recruited!"
      end)
      if ok and msg then
        MT.ui.flashSuccess(pnl, btnGen, cap, tostring(msg))
      elseif not ok then
        MT.ui.flashFail(pnl, btnGen, cap, tostring(msg))
      else
        MT.ui.flashSuccess(pnl, btnGen, cap, "招募成功 Recruited!")
      end
    end

  end
end

-- ============================================================
-- MARTIAL ARTS TAB -- full skill database browser (996 skills from live game memory)
-- ============================================================

do
  local MA_PAD = 10
  local _maSkills = {}       -- loaded from GameDataController
  local _maFilteredMap = {}  -- filtered index → _maSkills index
  local _maForceNames = {}   -- forceID → name

  -- ---- Filters (top bar) — positions scaled for F=13 ----
  -- ---- Filter row (auto-positioned via layout system) ----
  local FY = MA_PAD
  local maL = MT.ui.lay(tabMartial, {x=MA_PAD, y=FY, rowH=RH, btnH=BH})
  local fr = maL:inlineRow()
  fr:label("分类:")
  local catOpts = {"全部 All","内功","轻功","绝技","拳掌","剑法","刀法","长兵","奇门","射术"}
  local cmbCat = fr:combo(catOpts, 120)
  fr:label("品质:")
  local cmbRare = fr:combo({"全部","基础(0)","进阶(1)","上乘(2)","秘传(3)","顶极(4)","绝世(5)"}, 110)
  fr:label("门派:")
  local cmbSect = fr:combo({"全部 All","江湖 Jianghu"}, 130)
  local _dynStat = nil
  fr:label("属性列:")
  local cmbDynStat = fr:combo({"(无 None)"}, 160)
  fr:label("搜索:")
  local edtSearch = createEdit(tabMartial)
  edtSearch.Left = fr.x; edtSearch.Top = FY; edtSearch.Width = 180; edtSearch.Height = EH

  -- ---- ListView (single, full-width) ----
  local lv = createListView(tabMartial)
  lv.Left = MA_PAD; lv.Width = FW - MG * 4; lv.Height = 180
  lv.ViewStyle = vsReport; lv.RowSelect = true; lv.ReadOnly = true; lv.Font.Size = 13
  lv.OwnerData = true

  local cols = {
    {"ID", 35}, {"名称 Name", 0}, {"类型", 0}, {"品质", 0},
    {"门派", 0}, {"[属性]", 0}, {"内力", 0}, {"伤害", 0},
    {"释放", 0}, {"作用", 0},
    {"修炼 Upgrade", 0}, {"修炼+", 0}, {"装备 Equip", 0},
    {"使用 Use", 0}, {"伤害加成 DmgBonus", 0},
    {"效果 Effects", 0}, {"攻击架势", 0}, {"防御架势", 0},
  }
  local DYNAMIC_COL_IDX = 5  -- 0-based index of [属性] column (between 门派 and 内力)
  MT.ui.autoColumns(lv, cols, F)

  -- (dropdown already created above in filter bar)

  -- ---- Detail panel (below ListView) ----
  local detailMemo = createMemo(tabMartial)
  detailMemo.Left = MA_PAD; detailMemo.Top = MA_PAD + 232; detailMemo.Width = 1080; detailMemo.Height = 260
  detailMemo.ReadOnly = true; detailMemo.ScrollBars = ssVertical; detailMemo.Font.Size = 13
  detailMemo.Font.Name = "Consolas"
  detailMemo.WordWrap = true

  -- ---- Action bar (row 2, auto-positioned below filters) ----
  maL:advanceRow()
  local ABY = maL.y
  local ar = maL:inlineRow()
  lv.Top = ABY + RH          -- ListView = one full row below action bar
  -- Action bar controls (auto-positioned)
  ar:label("品质:")
  local edtAddRare = ar:edit("5", 40)
  local pnlAdd, btnAdd = ar:button("添加秘籍 Add Book", 180)
  ar:label("ID:")
  local edtByID = ar:edit("", 55)
  local pnlByID, btnByID = ar:button("Add", 60)
  ar:hintLabel("(品质 0=基础 5=绝世)")
  -- Count label at end of row
  local lblCount = createLabel(tabMartial)
  lblCount.Left = FW - 200; lblCount.Top = ABY + 4; lblCount.Caption = "0 / 0 skills"
  lblCount.Font.Color = 0x808080

  -- ---- Precompute display strings per skill (done once on load) ----
  local postureLabels = {"头","肩","胸","腹","臂","腿"}
  local function fmtPost(vals)
    if not vals or #vals == 0 then return "" end
    local p = {}
    for j, l in ipairs(postureLabels) do
      if vals[j] and vals[j] ~= 0 then p[#p+1] = l .. string.format("%.0f", vals[j]) end
    end
    return table.concat(p, " ")
  end

  -- Build display row cache: _maDisplayCache[skIdx] = {col0, col1, ...}
  local _maDisplayCache = {}
  local function buildDisplayCache()
    _maDisplayCache = {}
    for i, sk in ipairs(_maSkills) do
      _maDisplayCache[i] = {
        tostring(sk.id), sk.name, sk.typeName, sk.rareName,
        sk.forceName or "江湖",
        "",  -- placeholder for dynamic column (filled by OnData)
        sk.manaCost > 0 and string.format("%.0f", sk.manaCost) or "",
        sk.baseDmg > 0 and string.format("%.0f", sk.baseDmg) or "",
        sk.atkRange, sk.dmgRange or "",
        sk.upgrade,
        sk.upgradeTotal > 0 and string.format("%.0f", sk.upgradeTotal) or "",
        sk.equip, sk.use, sk.dmgBonus, sk.effects,
        fmtPost(sk.atkPosture), fmtPost(sk.defPosture),
      }
    end
  end

  -- Posture name → {field, index} mapping
  local _postureMap = {
    ["攻击头"]={1,true}, ["攻击肩"]={2,true}, ["攻击胸"]={3,true},
    ["攻击腹"]={4,true}, ["攻击臂"]={5,true}, ["攻击腿"]={6,true},
    ["防御头"]={1,false}, ["防御肩"]={2,false}, ["防御胸"]={3,false},
    ["防御腹"]={4,false}, ["防御臂"]={5,false}, ["防御腿"]={6,false},
  }

  -- Helper: get dynamic column value for a skill
  local function getDynValue(sk)
    if not _dynStat then return "" end
    -- Check posture
    local pm = _postureMap[_dynStat]
    if pm then
      local vals = pm[2] and sk.atkPosture or sk.defPosture
      local v = vals and vals[pm[1]] or 0
      if v == 0 then return "" end
      return string.format("%.0f", v)
    end
    -- Check damage bonus (伤害: prefix)
    local dmgName = _dynStat:match("^伤害:(.+)$")
    if dmgName then
      local val = sk._dmg and sk._dmg[dmgName] or 0
      if val == 0 then return "" end
      if val == math.floor(val) then return string.format("%.0f", val) end
      return string.format("%.1f", val)
    end
    -- Check effects (upgrade + equip + use)
    if not sk._upg then return "" end
    local val = (sk._upg[_dynStat] or 0) + (sk._eqp[_dynStat] or 0) + (sk._use[_dynStat] or 0)
    if val == 0 then return "" end
    if val == math.floor(val) then return string.format("%.0f", val) end
    return string.format("%.1f", val)
  end

  -- OwnerData callback: CE calls this to get text for each visible row
  lv.OnData = function(sender, item)
    local idx = item.Index + 1
    local skIdx = _maFilteredMap[idx]
    if not skIdx then return end
    local d = _maDisplayCache[skIdx]
    if not d then return end
    -- Fill dynamic column value at position 6 (0-based index 5)
    d[6] = getDynValue(_maSkills[skIdx])
    item.Caption = d[1]
    for c = 2, #d do item.SubItems.add(d[c]) end
  end

  -- ---- Refresh function (OwnerData: just filter + set count) ----
  local function refreshSkillList()
    _maFilteredMap = {}
    local catIdx = cmbCat.ItemIndex
    local rareIdx = cmbRare.ItemIndex
    local sectIdx = cmbSect.ItemIndex
    local searchText = edtSearch.Text:lower()

    for i, sk in ipairs(_maSkills) do
      if catIdx > 0 and sk.typeName ~= catOpts[catIdx + 1] then goto skip end
      if rareIdx > 0 and sk.rareLv ~= (rareIdx - 1) then goto skip end
      if sectIdx == 1 and sk.forceName ~= "江湖" then goto skip end
      if sectIdx > 1 then
        if sk.forceName ~= cmbSect.Items[sectIdx] then goto skip end
      end
      if #searchText > 0 then
        local haystack = (sk.name .. sk.desc .. sk.upgrade .. sk.equip .. sk.use .. sk.effects .. sk.dmgBonus):lower()
        if not haystack:find(searchText, 1, true) then goto skip end
      end
      _maFilteredMap[#_maFilteredMap + 1] = i
      ::skip::
    end
    lv.Items.Count = #_maFilteredMap
    lv.ItemIndex = -1  -- clear selection to prevent stale Add Book
    lv.Repaint()
    lblCount.Caption = string.format("%d / %d skills", #_maFilteredMap, #_maSkills)
  end

  -- ---- Column sorting ----
  local _maSortCol = nil
  local _maSortAsc = true
  -- Map column index to sort key: field name and whether numeric
  local sortKeys = {
    [0] = {f="id", num=true},        -- ID
    [1] = {f="name", num=false},     -- Name
    [2] = {f="typeName", num=false}, -- Type
    [3] = {f="rareLv", num=true},    -- Rarity
    [4] = {f="forceName", num=false},-- Sect
    [5] = {f="_dyn", num=true},      -- [属性] dynamic column
    [6] = {f="manaCost", num=true},  -- Mana
    [7] = {f="baseDmg", num=true},   -- Damage
    [8] = {f="atkRange", num=false}, -- 释放范围
    [9] = {f="dmgRange", num=false}, -- 作用范围
    [10] = {f="upgrade", num=false}, -- Upgrade text
    [11] = {f="upgradeTotal", num=true}, -- Upgrade total
    [12] = {f="equip", num=false},   -- Equip
    [13] = {f="use", num=false},     -- Use
    [14] = {f="dmgBonus", num=false},-- DmgBonus
    [15] = {f="effects", num=false}, -- Effects
    [16] = {f="atkPosture", num=false}, -- Atk posture
    [17] = {f="defPosture", num=false}, -- Def posture
  }

  -- Dynamic stat dropdown handler
  cmbDynStat.OnChange = function()
    local idx = cmbDynStat.ItemIndex
    if idx <= 0 then
      _dynStat = nil
      lv.Columns[DYNAMIC_COL_IDX].Caption = "[选择属性]"
    else
      _dynStat = cmbDynStat.Items[idx]
      lv.Columns[DYNAMIC_COL_IDX].Caption = _dynStat
    end
    lv.Items.Count = #_maFilteredMap
    lv.Repaint()
  end

  lv.OnColumnClick = function(sender, column)
    local colIdx = column.Index
    if _maSortCol == colIdx then
      _maSortAsc = not _maSortAsc
    else
      _maSortCol = colIdx
      _maSortAsc = true
    end
    local key = sortKeys[colIdx]
    if not key then return end
    table.sort(_maFilteredMap, function(a, b)
      local sa, sb = _maSkills[a], _maSkills[b]
      local va, vb
      if key.f == "_dyn" and _dynStat then
        -- Dynamic column: posture or effect stat
        local pm = _postureMap[_dynStat]
        if pm then
          local va_vals = pm[2] and sa.atkPosture or sa.defPosture
          local vb_vals = pm[2] and sb.atkPosture or sb.defPosture
          va = va_vals and va_vals[pm[1]] or 0
          vb = vb_vals and vb_vals[pm[1]] or 0
        else
          local dmgName = _dynStat:match("^伤害:(.+)$")
          if dmgName then
            va = sa._dmg and sa._dmg[dmgName] or 0
            vb = sb._dmg and sb._dmg[dmgName] or 0
          else
            va = (sa._upg and sa._upg[_dynStat] or 0) + (sa._eqp and sa._eqp[_dynStat] or 0) + (sa._use and sa._use[_dynStat] or 0)
            vb = (sb._upg and sb._upg[_dynStat] or 0) + (sb._eqp and sb._eqp[_dynStat] or 0) + (sb._use and sb._use[_dynStat] or 0)
          end
        end
      elseif key.num then
        va = tonumber(sa[key.f]) or 0
        vb = tonumber(sb[key.f]) or 0
      else
        va = tostring(sa[key.f] or "")
        vb = tostring(sb[key.f] or "")
      end
      if _maSortAsc then return va < vb else return va > vb end
    end)
    lv.Items.Count = #_maFilteredMap  -- force OwnerData refresh
    lv.Repaint()
  end

  -- ---- Detail panel update on selection ----
  local postureLabels = {"头", "肩", "胸", "腹", "臂", "腿"}
  local function formatPosture(vals)
    if not vals or #vals == 0 then return "" end
    local parts = {}
    for i, lbl in ipairs(postureLabels) do
      if vals[i] and vals[i] ~= 0 then parts[#parts+1] = lbl .. string.format("%.0f", vals[i]) end
    end
    return table.concat(parts, " ")
  end

  lv.OnSelectItem = function(sender, item, selected)
    if not selected then return end
    local selIdx = lv.ItemIndex
    if selIdx < 0 then return end
    local skIdx = _maFilteredMap[selIdx + 1]
    local sk = skIdx and _maSkills[skIdx]
    if not sk then return end

    local lines = {}
    lines[#lines+1] = string.format("[%s]  %s · %s · %s", sk.name, sk.rareName, sk.typeName, sk.forceName or "江湖")
    lines[#lines+1] = string.rep("-", 50)
    lines[#lines+1] = sk.desc
    lines[#lines+1] = ""
    if sk.weapon ~= "" then lines[#lines+1] = "武器 Weapon: " .. sk.weapon end
    if sk.manaCost > 0 then lines[#lines+1] = string.format("内力消耗 Mana: %.0f", sk.manaCost) end
    if sk.baseDmg > 0 then lines[#lines+1] = string.format("基础伤害 Damage: %.0f", sk.baseDmg) end
    if sk.atkRange and sk.atkRange ~= "" then lines[#lines+1] = "释放范围: " .. sk.atkRange end
    if sk.dmgRange and sk.dmgRange ~= "" and sk.dmgRange ~= "0-0" then lines[#lines+1] = "作用范围: " .. sk.dmgRange end
    if sk.dmgBonus and sk.dmgBonus ~= "" then lines[#lines+1] = "伤害加成: " .. sk.dmgBonus end
    if sk.use and sk.use ~= "" then lines[#lines+1] = ""; lines[#lines+1] = "使用效果 Use: " .. sk.use end
    if sk.upgrade ~= "" then lines[#lines+1] = "修炼效果 Upgrade: " .. sk.upgrade end
    if sk.equip ~= "" then lines[#lines+1] = "装备效果 Equip: " .. sk.equip end
    if sk.needs and sk.needs ~= "" then lines[#lines+1] = ""; lines[#lines+1] = "修炼需求: " .. sk.needs end
    local atkP = formatPosture(sk.atkPosture)
    local defP = formatPosture(sk.defPosture)
    if atkP ~= "" then lines[#lines+1] = ""; lines[#lines+1] = "攻击架势: " .. atkP end
    if defP ~= "" then lines[#lines+1] = "防御架势: " .. defP end
    if sk.effects ~= "" then lines[#lines+1] = ""; lines[#lines+1] = "特殊效果: " .. sk.effects end
    if sk.maxUse and sk.maxUse > 0 then lines[#lines+1] = "每场限用: " .. sk.maxUse end
    lines[#lines+1] = ""
    lines[#lines+1] = ""
    detailMemo.Lines.Text = table.concat(lines, "\r\n")
  end

  -- ---- Button handlers ----
  btnAdd.OnClick = function(sender)
    local cap = "添加秘籍 Add Book"
    local ok, msg = pcall(function()
      if not MT.ui.isConnected() then error("请先连接游戏 [Connect first]") end
      local selIdx = lv.ItemIndex
      if selIdx < 0 then error("请先选择武学 [Select a skill] idx=" .. selIdx) end
      local mapIdx = _maFilteredMap[selIdx + 1]
      if not mapIdx then error("mapIdx nil, selIdx=" .. selIdx .. " mapLen=" .. #_maFilteredMap) end
      local sk = _maSkills[mapIdx]
      if not sk then error("Skill nil at mapIdx=" .. mapIdx) end
      local rare = math.max(0, math.min(5, tonumber(edtAddRare.Text) or 5))
      local addOk, addMsg = MT.items.addBook(sk.id, rare)
      if not addOk then error(addMsg) end
      return addMsg
    end)
    if ok and msg then MT.ui.flashSuccess(pnlAdd, btnAdd, cap, tostring(msg))
    elseif not ok then MT.ui.flashFail(pnlAdd, btnAdd, cap, tostring(msg)) end
  end


  btnByID.OnClick = function(sender)
    local cap = "Add"
    local ok, msg = pcall(function()
      if not MT.ui.isConnected() then error("Connect first") end
      local id = tonumber(edtByID.Text)
      if not id then error("Invalid ID") end
      local rare = math.max(0, math.min(5, tonumber(edtAddRare.Text) or 5))
      local aOk, aMsg = MT.items.addBook(id, rare)
      if not aOk then error(aMsg) end
      return aMsg
    end)
    if ok and msg then MT.ui.flashSuccess(pnlByID, btnByID, cap, tostring(msg))
    elseif not ok then MT.ui.flashFail(pnlByID, btnByID, cap, tostring(msg)) end
  end

  -- ---- Wire filter events ----
  cmbCat.OnChange = function() refreshSkillList() end
  cmbRare.OnChange = function() refreshSkillList() end
  cmbSect.OnChange = function() refreshSkillList() end
  edtSearch.OnChange = function() refreshSkillList() end

  -- ---- Load skill data from embedded .dat file (no live connection needed) ----
  _maLoaderDone = false
_maTabTimer = createTimer()
  _maTabTimer.Interval = 500
  _maTabTimer.OnTimer = function(t)
    if _maLoaderDone then t.Enabled = false; return end
    if not _itemAdderForm then t.Enabled = false; return end
    local okV, vis = pcall(function() return _itemAdderForm.Visible end)
    if not okV or not vis then t.Enabled = false; return end
    local ok, isMA = pcall(function() return pc.ActivePage == tabMartial end)
    if not ok or not isMA then return end
    local skills = MT.data.loadSkillsFull()
    if skills and #skills > 0 then
      _maSkills = skills
      buildDisplayCache()
      -- Populate sect filter from skill data (forceName field is in the .dat)
      cmbSect.Items.clear()
      cmbSect.Items.add("全部 All")
      cmbSect.Items.add("江湖")
      local added = {}
      for _, sk in ipairs(_maSkills) do
        local fn = sk.forceName
        if fn and fn ~= "江湖" and fn ~= "" and not added[fn] then
          cmbSect.Items.add(fn)
          added[fn] = true
        end
      end
      cmbSect.ItemIndex = 0
      -- Populate dynamic stat dropdown (effects + posture)
      if MT.data._allStatNames then
        local sorted = {}
        for name in pairs(MT.data._allStatNames) do sorted[#sorted+1] = name end
        table.sort(sorted)
        for _, name in ipairs(sorted) do cmbDynStat.Items.add(name) end
        -- Add posture entries
        local postureNames = {
          "攻击头","攻击肩","攻击胸","攻击腹","攻击臂","攻击腿",
          "防御头","防御肩","防御胸","防御腹","防御臂","防御腿",
        }
        for _, name in ipairs(postureNames) do cmbDynStat.Items.add(name) end
      end
      _maLoaderDone = true
      t.Enabled = false
      refreshSkillList()
    end
  end
  _maTabTimer.Enabled = true

  -- Store references for form resize
  _maListView = lv
  _maDetailMemo = detailMemo
end

-- ============================================================
-- ITEMS TAB -- medicine, food, horse, material, equipment, treasure
-- ============================================================

do
  local mc = MT.ui.columns(tabItems, 2, {margin=MG, gap=CG*2, width=FW-MG*2, btnH=BH, rowH=RH, hdrSize=FH, y=MG})
  local L1 = mc:get(1)

  L1:section("药品 Medicine")
  local r = L1:inlineRow()
  local medData = MT.data.get("medDB") or {}
  local medItems = {}; for _, m in ipairs(medData) do medItems[#medItems+1] = m[1] .. " " .. m[2] end
  local cmbMed = r:combo(medItems, 260)
  r:button("添加 Add", 140, function()
    MT.game.checkAlive()
    local idx = cmbMed.ItemIndex
    if idx < 0 then error("请选择药品") end
    return select(2, assert(MT.items.addMedFood(medData[idx+1][1], 0x110)))
  end)
  L1:advanceRow()

  L1:section("食物 Food")
  r = L1:inlineRow()
  local foodData = MT.data.get("foodDB") or {}
  local foodItems = {}; for _, m in ipairs(foodData) do foodItems[#foodItems+1] = m[1] .. " " .. m[2] end
  local cmbFood = r:combo(foodItems, 260)
  r:button("添加 Add", 140, function()
    MT.game.checkAlive()
    local idx = cmbFood.ItemIndex
    if idx < 0 then error("请选择食物") end
    return select(2, assert(MT.items.addMedFood(foodData[idx+1][1], 0x118)))
  end)
  L1:advanceRow()

  L1:section("坐骑 Horse")
  r = L1:inlineRow()
  local horseData = MT.data.get("horseDB") or {}
  local horseItems = {}; for _, m in ipairs(horseData) do horseItems[#horseItems+1] = m[1] .. " " .. m[2] end
  local cmbHorse = r:combo(horseItems, 260)
  r:button("添加 Add", 140, function()
    MT.game.checkAlive()
    local idx = cmbHorse.ItemIndex
    if idx < 0 then error("请选择坐骑") end
    return select(2, assert(MT.items.addHorse(horseData[idx+1][1])))
  end)
  L1:advanceRow()

  -- Material + Treasure share a grid for perfect column alignment
  -- Columns: combo(160), label(50), edit(50), label(50), edit(50), button(130)
  local itemGrid = L1:grid({160, 50, 55, 50, 55, 160})

  L1:section("材料 Material")
  local matData = MT.data.get("matDB") or {}
  local matItems = {}; for _, m in ipairs(matData) do matItems[#matItems+1] = m[1] .. " " .. m[2] end
  local _, cmbMat, _, _, edtMatLv, _, _, edtMatRare
  local gr = itemGrid:row()
  gr, cmbMat = gr:combo(matItems)
  gr = gr:label("等级:")
  gr, edtMatLv = gr:edit("5")
  gr = gr:label("品质:")
  gr, edtMatRare = gr:edit("5")
  gr:button("添加 Add", nil, function()
    MT.game.checkAlive()
    local idx = cmbMat.ItemIndex
    if idx < 0 then error("请选择材料") end
    return select(2, assert(MT.items.addMaterial(matData[idx+1][1], tonumber(edtMatLv.Text) or 5, tonumber(edtMatRare.Text) or 5)))
  end)
  itemGrid:advanceRow()

  L1:section("珍品 Treasure")
  local _, cmbTreasure, _, _, edtTrLv, _, _, edtTrRare
  gr = itemGrid:row()
  gr, cmbTreasure = gr:combo({})
  for _, t in ipairs(MT.data.treasureTypes) do cmbTreasure.Items.add(t) end
  cmbTreasure.ItemIndex = 0
  gr = gr:label("等级:")
  gr, edtTrLv = gr:edit("5")
  gr = gr:label("品质:")
  gr, edtTrRare = gr:edit("5")
  gr:button("生成 Generate", nil, function()
    MT.game.checkAlive()
    if not MT.hook.TREASURE_GEN_RVA then error("RVA not resolved") end
    return select(2, assert(MT.items.addTreasure(cmbTreasure.ItemIndex, tonumber(edtTrLv.Text) or 5, tonumber(edtTrRare.Text) or 5)))
  end)
  itemGrid:advanceRow()

  L1:section("其他 Other")
  r = L1:inlineRow()
  r:button("品质全满 MaxRarity", 200, function()
    MT.game.checkAlive()
    return select(2, assert(pcall(MT.cheats.resources.maxRarity)))
  end)
  L1:advanceRow()
  -- Hint
  local lblItemHint = createLabel(tabItems)
  lblItemHint.Left = MG; lblItemHint.Top = L1.y
  lblItemHint.Caption = "品质 0=基础 5=绝世 | 等级=游戏难度系数"
  lblItemHint.Font.Size = FN; lblItemHint.Font.Color = 0x808080

  local L2 = mc:get(2)

  L2:section("装备 Equipment")
  r = L2:inlineRow()
  local cmbEquipType = r:combo({"武器 Weapon","铠甲 Armor","头盔 Helmet","鞋 Shoes","饰品 Accessory","马甲 HorseArmor"}, 170)
  local cmbEquipSub = r:combo({"(选择类型)"}, 220)
  L2:advanceRow()

  -- Populate sub-type dropdown from GDC database or staticItems
  local function populateEquipSub()
    cmbEquipSub.Items.clear()
    local typeIdx = cmbEquipType.ItemIndex
    local db = MT.hook.equipDBs[typeIdx + 1]
    if not db then return end
    if db.staticItems then
      for _, name in ipairs(db.staticItems) do cmbEquipSub.Items.add(name) end
    elseif db.off then
      pcall(function()
        local c = MT.il2cpp.init()
        if not c:ensure("gdc", "GameDataController", 0x20) then return end
        local gdcInst = readQword(c.gdc.static + c.gdc.instOff)
        if not gdcInst or gdcInst == 0 then return end
        local dbList = readQword(gdcInst + db.off)
        if not dbList or dbList == 0 then return end
        local dbItems = readQword(dbList + 0x10)
        local dbCount = readInteger(dbList + 0x18)
        if not dbItems or dbCount <= 0 then return end
        for i = 0, dbCount - 1 do
          local item = readQword(dbItems + 0x20 + i * 8)
          if item and item ~= 0 then
            local np = readQword(item + 0x20)
            local name = ""
            if np and np ~= 0 then
              local nl = readInteger(np + 0x10)
              if nl and nl > 0 then name = readString(np + 0x14, nl * 2, true) or "" end
            end
            cmbEquipSub.Items.add(string.format("%d %s", i, name))
          end
        end
      end)
      if cmbEquipSub.Items.Count == 0 then cmbEquipSub.Items.add("(需连接游戏)") end
    end
    if cmbEquipSub.Items.Count > 0 then cmbEquipSub.ItemIndex = 0 end
  end
  cmbEquipType.OnChange = function() populateEquipSub() end
  populateEquipSub()

  r = L2:inlineRow()
  r:label("等级:")
  local edtEqLv = r:edit("5", 45)
  r:label("品质:")
  local edtEqRare = r:edit("5", 45)
  r:button("生成 Generate", 160, function()
    MT.game.checkAlive()
    local typeIdx = cmbEquipType.ItemIndex
    local subIdx = cmbEquipSub.ItemIndex
    if subIdx < 0 then error("请选择子类型") end
    local db = MT.hook.equipDBs[typeIdx + 1]
    if not db or not db.genRVA then error("RVA not resolved") end
    return select(2, assert(MT.items.addEquipGenerated(db.genRVA, subIdx, tonumber(edtEqLv.Text) or 5, tonumber(edtEqRare.Text) or 5)))
  end)
  L2:advanceRow()
end

-- ============================================================
-- EVENTS TAB -- category filter + searchable event list + spawn
-- ============================================================

do
  -- Globals for event data (populated by background loader timer)
  _mtEvents = {}         -- array of {idx, addr, name, type, categories, search}
  _evtFilteredMap = {}   -- maps ListView row index -> _mtEvents index
  _evtListView = nil
  _evtRefreshList = nil
  _mtEdKlass = nil       -- EventData klass (for template verification)

  local EVT_PAD = MG

  -- Filter row (auto-positioned)
  local evtL = MT.ui.lay(tabEvents, {x=EVT_PAD, y=EVT_PAD, rowH=RH, btnH=BH, hdrSize=FH})
  local efr = evtL:inlineRow()
  efr:label("分类:")
  local cmbCat = efr:combo({"全部 All","门派 Sect","城镇 City","村庄 Village","客栈 Inn","探索 Explore","节日 Festival","大赛 Tournament","世界 World"}, 160)
  efr:label("搜索:")
  local edtSearch = createEdit(tabEvents)
  edtSearch.Left = efr.x; edtSearch.Top = EVT_PAD; edtSearch.Width = 200; edtSearch.Height = EH
  edtSearch.Text = ""
  efr.x = efr.x + 214
  efr:label("难度:")
  local edtDiff = efr:edit("-1", 60)
  evtL:advanceRow()

  -- ListView + right panel (two-column: ListView left, controls right)
  -- Use tab's actual client width (form width minus borders/padding)
  local tabW = tabEvents.ClientWidth or (FW - 30)
  local RIGHT_W = 280
  local LV_W = tabW - EVT_PAD * 2 - CG - RIGHT_W
  local RX = EVT_PAD + LV_W + CG

  local lv = createListView(tabEvents)
  lv.Left = EVT_PAD; lv.Top = evtL.y; lv.Width = LV_W; lv.Height = 400
  lv.ViewStyle = vsReport; lv.RowSelect = true; lv.ReadOnly = true
  MT.ui.autoColumns(lv, {{"#", 35}, {"名称 Name", 200}, {"分类 Category", 200}, {"类型 Type", 80}}, F)

  _evtListView = lv

  -- Right panel: count + spawn buttons + hints (auto-positioned)
  local evtR = MT.ui.lay(tabEvents, {x=RX, y=evtL.y, rowH=RH, btnH=BH})

  local lblCount = createLabel(tabEvents)
  lblCount.Left = RX; lblCount.Top = evtR.y + 4
  lblCount.Caption = "0 events"
  lblCount.Font.Color = 0x808080
  evtR:advanceRow()

  -- Refresh function -- filters _mtEvents by category + search, populates ListView
  local function refreshEventList()
    lv.Items.BeginUpdate()
    lv.Items.clear()
    _evtFilteredMap = {}
    local catIdx = cmbCat.ItemIndex
    local catNames = {"全部 All","门派 Sect","城镇 City","村庄 Village","客栈 Inn","探索 Explore","节日 Festival","大赛 Tournament","世界 World"}
    local filterCat = catNames[catIdx + 1]  -- Lua 1-based
    local searchText = string.lower(edtSearch.Text or "")
    local shown = 0

    for i, ev in ipairs(_mtEvents) do
      local passCategory = (filterCat == "全部 All")
      if not passCategory then
        passCategory = ev.categories[filterCat] or false
      end
      local passSearch = true
      if searchText ~= "" then
        passSearch = string.find(string.lower(ev.name or ""), searchText, 1, true) ~= nil
      end
      if passCategory and passSearch then
        shown = shown + 1
        _evtFilteredMap[shown] = i
        local item = lv.Items.add()
        item.Caption = tostring(shown)
        item.SubItems.add(ev.name or "?")
        -- Build category string
        local cats = {}
        for cat, _ in pairs(ev.categories) do cats[#cats+1] = cat end
        item.SubItems.add(table.concat(cats, ", "))
        item.SubItems.add(ev.type or "?")
      end
    end

    lv.Items.EndUpdate()
    lblCount.Caption = tostring(shown) .. " / " .. tostring(#_mtEvents) .. " events"
  end
  _evtRefreshList = refreshEventList

  -- Wire filter controls
  cmbCat.OnChange = function(sender) refreshEventList() end
  edtSearch.OnChange = function(sender) refreshEventList() end

  -- Spawn buttons (auto-positioned via layout)
  local sr = evtR:inlineRow()
  local pnlSpawn, btnSpawn = sr:button("生成到此处", 150)
  evtR:advanceRow()
  sr = evtR:inlineRow()
  local pnlSpawnWorld, btnSpawnWorld = sr:button("生成世界事件", 150)
  evtR:advanceRow()

  -- Enable/disable Spawn Event button based on selected event type
  lv.OnSelectItem = function(sender, item, selected)
    if not selected then return end
    local selIdx = lv.ItemIndex
    if selIdx < 0 then return end
    local evtIdx = _evtFilteredMap and _evtFilteredMap[selIdx + 1]
    local ev = evtIdx and _mtEvents and _mtEvents[evtIdx]
    local isWorld = ev and ev.type == "world"
    btnSpawnWorld.Enabled = isWorld
    pnlSpawnWorld.Color = isWorld and 0xFFFFFF or 0xC0C0C0
  end

  table.insert(_threadGatedControls, {panel = pnlSpawn, btn = btnSpawn})

  -- Cache for festival/tournament template scans (lazy, one per type)
  local _festTplCache = {}

  -- Festival/tournament template finder: AOB scan for UTF-16 name, trace back to EventData
  local function findEventTemplate(searchBytes)
    local key = table.concat(searchBytes, ",")
    if _festTplCache[key] then return _festTplCache[key] end

    local aob = ""
    for si, b in ipairs(searchBytes) do
      if si > 1 then aob = aob .. " " end
      aob = aob .. string.format("%02X", b)
    end

    local scanResult = AOBScan(aob, "+W")
    if not scanResult then return nil end

    -- We need _mtEdKlass to verify the object is an EventData
    local edKlass = _mtEdKlass
    if not edKlass then
      object_destroy(scanResult)
      return nil
    end

    local nChars = #searchBytes / 2
    local templateED = nil
    for i = 0, stringlist_getCount(scanResult) - 1 do
      local charAddr = tonumber(stringlist_getString(scanResult, i), 16)
      -- Verify string length matches
      local strLen = readInteger(charAddr - 4)
      if strLen and strLen == nChars then
        local strObj = charAddr - 0x14
        -- Search for pointer to this string at EventData.eventName (+0x10)
        local sb = string.format("%02X %02X %02X %02X %02X %02X 00 00",
          strObj & 0xFF, (strObj >> 8) & 0xFF, (strObj >> 16) & 0xFF,
          (strObj >> 24) & 0xFF, (strObj >> 32) & 0xFF, (strObj >> 40) & 0xFF)
        local refs = AOBScan(sb, "+W")
        if refs then
          for j = 0, stringlist_getCount(refs) - 1 do
            local refAddr = tonumber(stringlist_getString(refs, j), 16)
            local possibleED = refAddr - 0x10
            if readQword(possibleED) == edKlass then
              -- Verify it's a template (isAreaEvent=0, leftTime=0)
              if readBytes(possibleED + 0x30, 1) == 0 and readInteger(possibleED + 0x60) == 0 then
                templateED = possibleED
                break
              end
            end
          end
          object_destroy(refs)
        end
        if templateED then break end
      end
    end
    object_destroy(scanResult)

    if templateED then _festTplCache[key] = templateED end
    return templateED
  end

  -- Spawn an event by cloning its EventData template
  local function spawnSpecialEvent(ev, difficulty)
    local S = MT.hook.S
    if not S.ready or not S.cmdBuf then return false, "Connect first" end

    -- Get template address
    local templateED = ev.addr
    if not templateED and ev.search then
      templateED = findEventTemplate(ev.search)
    end
    if not templateED and ev.templateIdx then
      -- World events: resolve from WorldEventController DB list
      local c0 = MT.il2cpp.init()
      local wecClass = c0.findClass("WorldEventController")
      if wecClass then
        local wecSF = readQword(wecClass + 0xB8)
        local wecInst = wecSF and readQword(wecSF) or 0
        if wecInst ~= 0 then
          local dbList = readQword(wecInst + 0x18)
          if dbList and dbList ~= 0 then
            local dbCount = readInteger(dbList + 0x18)
            if ev.templateIdx < dbCount then
              local items = readQword(dbList + 0x10)
              templateED = readQword(items + 0x20 + ev.templateIdx * 8)
            end
          end
        end
      end
    end
    if not templateED or templateED == 0 then return false, "模板未找到 Template not found" end
    MT.log.write(string.format("[EventTab] Spawning %s from template %X", ev.name, templateED))

    local c = MT.il2cpp.init()
    local getMeth = getAddress("GameAssembly.il2cpp_class_get_method_from_name")
    local riAddr = getAddress("GameAssembly.il2cpp_runtime_invoke")
    if not riAddr or riAddr == 0 then return false, "runtime_invoke not found" end
    local cb = S.cmdBuf

    -- World events: template is WorldEventDataBase, not EventData
    -- WorldEventDataBase.eventData at +0x50 is the actual EventData to clone
    if ev.type == "world" then
      templateED = readQword(templateED + 0x50)
      if not templateED or templateED == 0 then return false, "EventData not found in WorldEventDataBase" end
    end

    -- Non-world events: Clone via EventData.Clone()
    local edKlass = _mtEdKlass
    local cloneBuf = allocateMemory(32); writeString(cloneBuf, "Clone")
    local cloneMI = executeCodeEx(0, nil, getMeth, edKlass, cloneBuf, 0)
    deAlloc(cloneBuf)
    if not cloneMI or cloneMI == 0 then return false, "EventData.Clone MI not found" end

    writeQword(cb + 0x90, cloneMI)
    writeQword(cb + 0x88, templateED)
    writeQword(cb + 0xA0, 0)
    writeQword(cb + 0x68, riAddr)
    writeInteger(cb + 0x04, 0)
    writeInteger(cb, 8)
    local elapsed = 0
    while elapsed < 5000 do
      if readInteger(cb + 0x04) ~= 0 then break end
      sleep(16); elapsed = elapsed + 16
    end
    if readInteger(cb + 0x04) ~= 1 then return false, "Clone failed" end
    local clonedED = readQword(cb + 0x08)
    if not clonedED or clonedED == 0 then return false, "Clone returned null" end

    -- Set runtime fields on the clone
    writeBytes(clonedED + 0x5E, {1})     -- autoDestroy = true
    writeInteger(clonedED + 0x60, 15)    -- leftTime = 15 days
    -- Set difficulty
    if difficulty then
      writeFloat(clonedED + 0x64, difficulty * 1.0)
    else
      local gcI = readQword(c.gc.static + c.gc.instOff)
      local wd = readQword(gcI + 0x20)
      local timeDiff = wd and readFloat(wd + 0xB0) or 5.0
      local randVal = math.random() * 0.4 + 0.8
      writeFloat(clonedED + 0x64, timeDiff * randVal)
    end

    local gcInst = readQword(c.gc.static + c.gc.instOff)
    local worldData = readQword(gcInst + 0x20)
    local heroList = readQword(worldData + 0x50)
    local heroItems = readQword(heroList + 0x10)
    local playerHero = readQword(heroItems + 0x20)
    local playerAreaID = readInteger(playerHero + 0xC0)
    if not playerAreaID or playerAreaID == 0xFFFFFFFF or playerAreaID < 0 then
      return false, "大地图无法生成 [Can't spawn on BigMap]"
    end

    -- CreateAreaMapRandomEvent requires player to be in an area map (town/village)
    writeBytes(clonedED + 0x30, {1})  -- isAreaEvent = true

    local camBuf = allocateMemory(64); writeString(camBuf, "CreateAreaMapRandomEvent")
    local camMI = executeCodeEx(0, nil, getMeth, c.gc.klass, camBuf, 2)
    deAlloc(camBuf)
    if not camMI or camMI == 0 then return false, "CreateAreaMapRandomEvent MI not found" end

    -- Count events before call to detect if spawn succeeded despite exception
    local eventList = readQword(worldData + 0x68)
    local countBefore = eventList and readInteger(eventList + 0x18) or 0

    writeQword(cb + 0xA0, clonedED)
    writeInteger(cb + 0xB0, playerAreaID)
    writeQword(cb + 0xA8, cb + 0xB0)
    writeQword(cb + 0x90, camMI)
    writeQword(cb + 0x88, gcInst)
    writeQword(cb + 0x68, riAddr)
    writeInteger(cb + 0x04, 0)
    writeInteger(cb, 8)

    elapsed = 0
    while elapsed < 5000 do
      if readInteger(cb + 0x04) ~= 0 then break end
      sleep(16); elapsed = elapsed + 16
    end
    local status = readInteger(cb + 0x04)
    if status == 1 then
      return true, ev.name .. " 已生成 spawned"
    else
      -- Check if event was actually added despite the exception
      local countAfter = eventList and readInteger(eventList + 0x18) or 0
      if countAfter > countBefore then
        return true, ev.name .. " 已生成 spawned (异常难度 abnormal difficulty)"
      end
      return false, "CreateAreaMapRandomEvent failed (status=" .. tostring(status) .. ")"
    end
  end

  -- Spawn a world event via WorldEventController.CreateWorldEvent (v6 approach)
  local _wecCreateMI = nil
  local function spawnWorldEvent(ev, difficulty)
    local S = MT.hook.S
    if not S.ready or not S.cmdBuf then return false, "Connect first" end
    local c = MT.il2cpp.init()
    local cb = S.cmdBuf
    local getMeth = getAddress("GameAssembly.il2cpp_class_get_method_from_name")
    local riAddr = getAddress("GameAssembly.il2cpp_runtime_invoke")
    if not riAddr or riAddr == 0 then return false, "runtime_invoke not found" end

    -- Find WorldEventController._instance
    local wecClass = c.findClass("WorldEventController")
    if not wecClass then return false, "WorldEventController not found" end
    local wecSF = readQword(wecClass + 0xB8)
    if not wecSF or wecSF == 0 then return false, "WEC static=0" end
    local wecInst = readQword(wecSF)
    if not wecInst or wecInst == 0 then return false, "WEC instance=0" end

    -- Get template from WEC DB list
    local dbList = readQword(wecInst + 0x18)
    if not dbList or dbList == 0 then return false, "WEC dbList=0" end
    local dbCount = readInteger(dbList + 0x18)
    if ev.templateIdx >= dbCount then return false, "Template index out of range" end
    local items = readQword(dbList + 0x10)
    local template = readQword(items + 0x20 + ev.templateIdx * 8)
    if not template or template == 0 then return false, "Template null" end

    -- Resolve CreateWorldEvent(EventData) on WEC (1 param)
    if not _wecCreateMI then
      local wecKlass = readQword(wecInst)
      local strBuf = allocateMemory(64); writeString(strBuf, "CreateWorldEvent")
      _wecCreateMI = executeCodeEx(0, nil, getMeth, wecKlass, strBuf, 1)
      deAlloc(strBuf)
      if not _wecCreateMI or _wecCreateMI == 0 then
        _wecCreateMI = nil
        return false, "CreateWorldEvent MI not found"
      end
    end

    -- Set difficulty on template before spawn
    local origDiff = readFloat(template + 0x64)
    if difficulty then writeFloat(template + 0x64, difficulty * 1.0) end

    writeQword(cb + 0xA0, template)
    writeQword(cb + 0x90, _wecCreateMI)
    writeQword(cb + 0x88, wecInst)
    writeQword(cb + 0x68, riAddr)
    writeQword(cb + 0x98, 0)
    writeInteger(cb + 0x04, 0)
    writeInteger(cb, 8)

    local elapsed = 0
    while elapsed < 5000 do
      if readInteger(cb + 0x04) ~= 0 then break end
      sleep(16); elapsed = elapsed + 16
    end

    -- Restore original difficulty
    if difficulty then writeFloat(template + 0x64, origDiff) end

    local status = readInteger(cb + 0x04)
    if status == 1 then
      return true, ev.name .. " 已生成 spawned"
    else
      return false, "CreateWorldEvent failed (status=" .. tostring(status) .. ")"
    end
  end

  -- Helper: get selected event and difficulty
  local function getSelectedEvent()
    if not MT.ui.isConnected() then error("请先连接游戏 [Connect first]") end
    local selIdx = lv.ItemIndex
    if selIdx < 0 then error("请先选择一个事件 [Select an event first]") end
    local evtIdx = _evtFilteredMap[selIdx + 1]
    if not evtIdx then error("Invalid selection") end
    local ev = _mtEvents[evtIdx]
    if not ev then error("Event data not found") end
    local diffVal = tonumber(edtDiff.Text) or -1
    local difficulty = nil
    if diffVal >= 0 then difficulty = diffVal end
    return ev, difficulty
  end

  -- Spawn Here button (CreateAreaMapRandomEvent — requires being in an area)
  btnSpawn.OnClick = function(sender)
    local cap = "生成到此处 Spawn Here"
    local ok, msg = pcall(function()
      local ev, difficulty = getSelectedEvent()
      if ev.type == "random" then
        if not ev.addr then error("事件地址未找到 Event address not found") end
      end
      local spOk, spMsg = spawnSpecialEvent(ev, difficulty)
      if not spOk then error(spMsg) end
      return spMsg
    end)
    if ok and msg then
      MT.ui.flashSuccess(pnlSpawn, btnSpawn, cap, tostring(msg))
    elseif not ok then
      MT.ui.flashFail(pnlSpawn, btnSpawn, cap, tostring(msg))
    else
      MT.ui.flashSuccess(pnlSpawn, btnSpawn, cap, "Event spawned!")
    end
  end

  -- Spawn Event button (CreateWorldEvent — world events only, works anywhere)
  btnSpawnWorld.OnClick = function(sender)
    local cap = "生成事件 Spawn Event"
    local ok, msg = pcall(function()
      local ev, difficulty = getSelectedEvent()
      if ev.type ~= "world" then error("仅限世界事件 [World events only]") end
      local spOk, spMsg = spawnWorldEvent(ev, difficulty)
      if not spOk then error(spMsg) end
      return spMsg
    end)
    if ok and msg then
      MT.ui.flashSuccess(pnlSpawnWorld, btnSpawnWorld, cap, tostring(msg))
    elseif not ok then
      MT.ui.flashFail(pnlSpawnWorld, btnSpawnWorld, cap, tostring(msg))
    end
  end

  -- Hint labels
  evtR:sectionGap()
  local lblHint1 = createLabel(tabEvents)
  lblHint1.Left = RX; lblHint1.Top = evtR.y
  lblHint1.Caption = "难度 0-11=正常 12+=异常"
  lblHint1.Font.Size = FN; lblHint1.Font.Color = 0x808080
  evtR:skip(20)
  local lblHint2 = createLabel(tabEvents)
  lblHint2.Left = RX; lblHint2.Top = evtR.y
  lblHint2.Caption = "此处=区域内 事件=任何位置"
  lblHint2.Font.Size = FN; lblHint2.Font.Color = 0x808080
  evtR:skip(20)
  local lblHint3 = createLabel(tabEvents)
  lblHint3.Left = RX; lblHint3.Top = evtR.y
  lblHint3.Caption = "事件按钮仅限世界事件"
  lblHint3.Font.Size = FN; lblHint3.Font.Color = 0x808080

  -- Store right-panel controls for resize handler
  _evtRightControls = {lblCount, pnlSpawn, pnlSpawnWorld, lblHint1, lblHint2, lblHint3}
end

-- ============================================================
-- STATUS BAR (bottom of form)
-- ============================================================

local lblStatus = createLabel(frm)
lblStatus.Left = MG
lblStatus.Top = frm.ClientHeight - HH
lblStatus.Width = FW - MG * 2
lblStatus.AutoSize = false
lblStatus.WordWrap = false
lblStatus.Caption = "就绪 [Ready]"
lblStatus.Font.Size = FN
lblStatus.Font.Color = 0x808080

-- Publish globals for cross-script access
_mtStatusLbl = lblStatus
_itemAdderForm = frm

-- Close handler: kill all timers to prevent C stack overflow from _index recursion
frm.OnClose = function(sender, action)
  _itemAdderForm = nil
  _mtStatusLbl = nil
  local timers = {_maTabTimer, _evtLoaderTimer}
  for _, t in ipairs(timers) do
    if t then pcall(function() t.Enabled = false; t.destroy() end) end
  end
  _maTabTimer = nil
  _evtLoaderTimer = nil
  _threadGatedControls = {}
  return caFree
end

-- Resize handler: scale PageControl and Martial Arts tab controls with form
frm.OnResize = function(sender)
  local w = frm.ClientWidth
  local h = frm.ClientHeight
  pc.Width = w - 8
  pc.Height = h - TH - 50
  -- Reposition status bar
  if _mtStatusLbl then _mtStatusLbl.Top = h - HH; _mtStatusLbl.Width = w - 20 end
  -- Martial Arts tab controls
  if _maListView then
    _maListView.Width = w - 20
    _maListView.Top = MG + RH * 2  -- below filters + action bar
    -- Split: ListView gets top portion, detail memo gets bottom
    local detailH = 170
    local lvH = pc.Height - 58 - detailH - 14
    if lvH < 80 then lvH = 80 end
    _maListView.Height = lvH
    if _maDetailMemo then
      _maDetailMemo.Top = _maListView.Top + lvH + 4
      _maDetailMemo.Width = w - 20
      _maDetailMemo.Height = pc.Height - _maDetailMemo.Top - 10
    end
  end
  -- Events tab controls
  if _evtListView then
    local evtRX = w - 210
    _evtListView.Width = evtRX - 20
    _evtListView.Height = pc.Height - 60
    if _evtRightControls then
      for _, ctrl in ipairs(_evtRightControls) do
        pcall(function() ctrl.Left = evtRX end)
      end
    end
  end
end

-- ============================================================
-- BACKGROUND EVENT LOADER -- fires every 2s, loads data once after Connect
-- ============================================================

_evtLoaderTimer = createTimer()
_evtLoaderTimer.Interval = 2000
_evtLoaderTimer.OnTimer = function(t)
  local S = MT.hook.S
  if not S or not S.ready then return end  -- wait for Connect
  t.Enabled = false; t.destroy()

  pcall(function()
    _mtEvents = {}
    local c = MT.il2cpp.init()
    -- Find RandomEventController
    local recClass = c.findClass("RandomEventController")
    if not recClass then return end
    local recInst = readQword(readQword(recClass + 0xB8))
    if not recInst or recInst == 0 then return end
    local reDB = readQword(recInst + 0x18)
    if not reDB or reDB == 0 then return end
    local reCnt = readInteger(reDB + 0x18) or 0
    local reItems = readQword(reDB + 0x10)
    if not reItems or reItems == 0 then return end

    _mtEdKlass = readQword(readQword(reItems + 0x20))  -- EventData klass

    -- Read all random events (just memory reads, instant)
    local function readStr(ptr)
      if not ptr or ptr == 0 then return "?" end
      local nl = readInteger(ptr + 0x10)
      if not nl or nl <= 0 or nl > 200 then return "?" end
      return readString(ptr + 0x14, nl * 2, true) or "?"
    end

    for i = 0, reCnt - 1 do
      local e = readQword(reItems + 0x20 + i * 8)
      if e and e ~= 0 then
        _mtEvents[#_mtEvents+1] = {idx=i, addr=e, name=readStr(readQword(e+0x10)),
          type="random", categories={}}
      end
    end

    -- Tag categories from index lists
    local function tagCat(off, cat)
      local list = readQword(recInst + off)
      if not list or list == 0 then return end
      local cnt = readInteger(list + 0x18) or 0
      local items = readQword(list + 0x10)
      if not items then return end
      for i = 0, cnt - 1 do
        local idx = readInteger(items + 0x20 + i * 4)
        if idx then
          for _, ev in ipairs(_mtEvents) do
            if ev.idx == idx then ev.categories[cat] = true; break end
          end
        end
      end
    end
    tagCat(0x38, "门派 Sect")
    tagCat(0x48, "城镇 City")
    tagCat(0x50, "村庄 Village")
    tagCat(0x58, "客栈 Inn")
    tagCat(0x28, "探索 Explore")
    tagCat(0x30, "大地图 BigMap")

    -- Hardcoded festivals (template addr found lazily at spawn)
    local festivals = {"春节 Spring","元宵 Lantern","清明 QingMing","端午 DragonBoat",
      "七夕 QiXi","中秋 MidAutumn","重阳 ChongYang","腊八 LaBa"}
    local festSearch = {
      {0x25,0x66,0x82,0x82},{0x43,0x51,0xB5,0x5B},{0x05,0x6E,0x0E,0x66},{0xEF,0x7A,0x48,0x53},
      {0x03,0x4E,0x15,0x59},{0x2D,0x4E,0xCB,0x79},{0xCD,0x91,0x33,0x96},{0x4A,0x81,0x6B,0x51},
    }
    for fi, fn in ipairs(festivals) do
      _mtEvents[#_mtEvents+1] = {idx=-1, addr=nil, name=fn, type="festival",
        search=festSearch[fi], categories={["节日 Festival"]=true}}
    end

    -- Hardcoded tournaments
    local tourns = {"比武大赛 FightTourney","辩才大赛 DebateTourney","赛马大会 HorseRace",
      "拍卖大会 Auction","门派大比 SectContest"}
    local tournSearch = {
      {0x14,0x6B,0xE6,0x6B,0x27,0x59,0xDB,0x8D},{0xA9,0x8F,0x4D,0x62,0x27,0x59,0xDB,0x8D},
      {0x5B,0x8D,0x6C,0x9A,0x27,0x59,0x1A,0x4F},{0xCD,0x62,0x56,0x53,0x27,0x59,0x1A,0x4F},
      {0xE8,0x95,0x3E,0x6D,0x27,0x59,0x14,0x6B},
    }
    for ti, tn in ipairs(tourns) do
      _mtEvents[#_mtEvents+1] = {idx=-1, addr=nil, name=tn, type="tournament",
        search=tournSearch[ti], categories={["大赛 Tournament"]=true}}
    end

    -- Hardcoded world events (from v6, use WorldEventController.CreateWorldEvent)
    local worldEvts = {
      {13, "异草奇花 Rare Herb"}, {14, "仙木灵果 Spirit Fruit"},
      {15, "失落宝藏 Lost Treasure"}, {16, "神兵现世 Divine Weapon"},
      {17, "失传秘籍 Lost Manual"}, {18, "千里名驹 Famous Horse"},
      {19, "武学奇才 Martial Prodigy"}, {20, "世外高人 Hidden Master"},
      {21, "皇家宝库 Royal Treasury"}, {22, "神秘石碑 Mysterious Stele"},
    }
    for _, we in ipairs(worldEvts) do
      _mtEvents[#_mtEvents+1] = {idx=-1, addr=nil, name=we[2], type="world",
        templateIdx=we[1], categories={["世界 World"]=true}}
    end

    -- Refresh the Events tab list
    if _evtRefreshList then _evtRefreshList() end
    MT.log.write(string.format("[EventTab] Loaded %d events", #_mtEvents))
  end)
end
_evtLoaderTimer.Enabled = true

-- ============================================================
-- SHOW
-- ============================================================

frm.Show()
end) -- end pcall(_formOk)

if not _formOk then
  local msg = tostring(_formErr)
  if MT.diag then MT.diag("[form] CREATION ERROR: " .. msg) end
  showMessage("多功能工具创建失败 / Multi-Tool form error:\n\n" .. msg .. "\n\n请截图此错误并反馈\nPlease screenshot this error and report it.")
  pcall(function() if _itemAdderForm then _itemAdderForm.destroy() end end)
  _itemAdderForm = nil
end
{$asm}

[DISABLE]
{$lua}
if syntaxcheck then return end

pcall(function()
  -- 1. Destroy GUI
  if _itemAdderForm then _itemAdderForm.destroy(); _itemAdderForm = nil end
  _mtStatusLbl = nil
  _threadGatedControls = {}

  if type(MT) ~= "table" then return end

  -- 2. Restore all toggle/patch state via MT.cheats disable functions
  pcall(MT.cheats.sect.memberLimitDisable)
  pcall(MT.cheats.sect.noCostDisable)
  pcall(MT.cheats.stats.talentSlotDisable)
  pcall(MT.cheats.stats.combatExpDisable)
  pcall(MT.cheats.stats.livingExpDisable)
  pcall(MT.cheats.battle.battleSpeedDisable)
  pcall(MT.cheats.explore.horseSpeedDisable)
  pcall(MT.cheats.stats.creationTalentSlotDisable)
  -- Talent cap patch (GetMaxTagNum) -- uses global _sectTalentCapPatches
  if _sectTalentCapPatches then
    pcall(function()
      local c2 = MT.il2cpp.init()
      if c2:ensure("hd", "HeroData") then
        local addr = MT.method.findAddr(c2.hd.klass, "GetMaxTagNum")
        if addr then
          for i = 1, #_sectTalentCapPatches do writeBytes(addr + i - 1, _sectTalentCapPatches[i]) end
        end
      end
    end)
    _sectTalentCapPatches = nil
  end

  -- 3. Clean up hook, dealloc memory, restore Update
  MT.hook.cleanup()
end)
{$asm}
