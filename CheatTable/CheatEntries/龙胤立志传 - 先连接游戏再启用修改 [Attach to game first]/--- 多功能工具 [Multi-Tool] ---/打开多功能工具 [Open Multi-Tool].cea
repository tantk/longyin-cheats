  MT.ui.makeInput(tabGeneral, COL1_X, y1, BTN_W, BTN_H, "设置陨铁 Meteorite", 80, "999", MT.cheats.resources.setMeteorite, false)
  y1 = y1 + ROW_H + SECTION_GAP

  sectionLabel(tabGeneral, COL1_X, y1, "属性/天赋 Stats/Talents")
