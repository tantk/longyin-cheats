  MT.ui.makeInput(tabGeneral, COL1_X, y1, BTN_W, BTN_H, "属性上限 StatCaps", 80, "99", MT.cheats.stats.setStatCaps, false)
  y1 = y1 + ROW_H

  MT.ui.makeToggleInput(tabGeneral, COL1_X, y1, BTN_W, BTN_H, "天赋槽 TalentSlot", 80, "99",
    MT.cheats.stats.talentSlotEnable, MT.cheats.stats.talentSlotDisable, false)
  y1 = y1 + ROW_H

  MT.ui.makeInput(tabGeneral, COL1_X, y1, BTN_W, BTN_H, "天赋点 TalentPts", 80, "100", MT.cheats.stats.setTalentPoints, false)
  y1 = y1 + ROW_H + SECTION_GAP

  sectionLabel(tabGeneral, COL1_X, y1, "声望 Reputation")
  y1 = y1 + HH

  MT.ui.makeInput(tabGeneral, COL1_X, y1, BTN_W, BTN_H, "设置声望 Fame", 80, "1000", MT.cheats.stats.setFame, false)
  y1 = y1 + ROW_H

  MT.ui.makeOneOff(tabGeneral, COL1_X, y1, BTN_W, BTN_H, "好感全满 MaxFavor", MT.cheats.stats.maxNpcFavor, false)
